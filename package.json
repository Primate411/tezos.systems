{
  "name": "tezos.systems",
  "version": "1.0.0",
  "description": "Real-time network statistics dashboard for the Tezos blockchain. Tracks consensus, economics, governance, network activity, and ecosystem metrics with live data.",
  "main": "sw.js",
  "scripts": {
    "install-hooks": "git config core.hooksPath .githooks",
    "guard:readme": "node scripts/guard-readme-sync.mjs",
    "check:readme": "node tests/static-checks.mjs --readme-only",
    "check:supabase": "node scripts/check-supabase-history-schema.mjs",
    "backfill:supabase": "node scripts/backfill-supabase-history.mjs",
    "test": "npm run test:static && npm run test:smoke",
    "test:static": "node tests/static-checks.mjs",
    "test:smoke": "node tests/smoke.mjs",
    "test:smoke:list": "node tests/smoke.mjs --list",
    "test:smoke:headed": "node tests/smoke.mjs --headed",
    "test:smoke:strict": "node tests/smoke.mjs --strict-external",
    "test:smoke:live": "node tests/smoke.mjs --base-url https://tezos.systems",
    "serve": "python3 -m http.server 9000",
    "build:css": "node scripts/build-css.mjs",
    "og:chambers": "node scripts/generate-chamber-og-images.mjs",
    "routes:chambers": "node scripts/generate-chamber-routes.mjs",
    "bake:compare": "node scripts/bake-compare-pages.mjs",
    "refresh:governance": "node scripts/refresh-governance-data.mjs",
    "update:governance-votes": "node scripts/update-governance-votes.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Primate411/tezos.systems.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Primate411/tezos.systems/issues"
  },
  "homepage": "https://github.com/Primate411/tezos.systems#readme",
  "dependencies": {
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "knip": "^6.3.1",
    "sharp": "^0.35.1"
  }
}
